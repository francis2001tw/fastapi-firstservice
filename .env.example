# ============================================================
# ⚠️ 安全警告: 此文件仅为模板, 请复制为 .env 并填入真实值
# ⚠️ 绝不要将 .env 提交到 Git 仓库
# ⚠️ 如果任何 Key 泄露, 请立即到 Supabase Dashboard 轮换/撤销
# ============================================================

# ---------- Supabase 配置 ----------
SUPABASE_URL=https://zqaxmyppqfckbpgizmqg.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Secret: 在 Supabase Dashboard → Settings → API → JWT Secret 获取
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ---------- 微信开放平台配置 ----------
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
# true = 使用模拟微信登录 (无需真实 appid/secret); false = 真实微信 OAuth
WECHAT_MOCK_MODE=true

# ---------- 应用配置 ----------
FRONTEND_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
